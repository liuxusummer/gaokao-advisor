{
  "name": "gaokao-advisor",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:file": "tsc -b && VITE_ROUTER_MODE=hash vite build --base=./ --outDir dist-file",
    "lint": "eslint .",
    "preview": "vite preview",
    "scrape:colleges": "tsx scripts/scrapers/colleges/index.ts",
    "scrape:colleges:force": "tsx scripts/scrapers/colleges/index.ts --force",
    "scrape:colleges:dry": "tsx scripts/scrapers/colleges/index.ts --dry-run",
    "scrape:colleges:websites": "tsx scripts/scrapers/colleges/website_enricher.ts",
    "scrape:majors": "tsx scripts/scrapers/majors/index.ts",
    "scrape:majors:detail": "tsx scripts/scrapers/majors/detail/index.ts",
    "scrape:subjects": "tsx scripts/scrapers/subjects/index.ts",
    "scrape:scores": "tsx scripts/scrapers/scores/index.ts",
    "scrape:scores:force": "tsx scripts/scrapers/scores/index.ts --force",
    "scrape:rank_tables": "tsx scripts/scrapers/rank_tables/index.ts",
    "scrape:rank_tables:force": "tsx scripts/scrapers/rank_tables/index.ts --force",
    "scrape:all": "npm run scrape:colleges && npm run scrape:scores && npm run scrape:rank_tables",
    "test:scrapers": "vitest run scripts/scrapers",
    "test:scrapers:watch": "vitest scripts/scrapers"
  },
  "dependencies": {
    "@ant-design/icons": "^5.6.1",
    "@types/adm-zip": "^0.5.8",
    "adm-zip": "^0.5.17",
    "antd": "^5.29.3",
    "dexie": "^4.4.4",
    "echarts": "^5.6.0",
    "framer-motion": "^11.18.2",
    "iconv-lite": "^0.7.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/cheerio": "^0.22.35",
    "@types/node": "^24.12.3",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "axios": "^1.18.0",
    "cheerio": "^1.2.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^24.1.3",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.61.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "tesseract.js": "^7.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^5.4.21",
    "vitest": "^1.6.1"
  }
}
